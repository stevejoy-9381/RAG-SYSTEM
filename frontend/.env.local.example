# frontend/.env.local.example
# Copy to .env.local and fill in values

# Where the FastAPI backend is running.
# NEXT_PUBLIC_ prefix = exposed to the browser (required for client-side fetch calls).
#
# Local dev (no Docker):  http://localhost:8000
# Docker Compose:         http://localhost:8000  (ports are mapped to host)
# Production (Render):    https://docmind-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000
