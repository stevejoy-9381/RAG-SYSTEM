# ─────────────────────────────────────────────────────────────────────────────
# RAG Document Q&A — Environment Variables (Phase 3: Auth added)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy:  cp .env.example .env
# 2. Fill in real values below
# 3. NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Phase 3 NEW: Auth ─────────────────────────────────────────────────────────
# JWT secret key — used to sign and verify tokens.
# MUST be a long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If this key is leaked, anyone can forge auth tokens.
# If you change it, all existing sessions are immediately invalidated.
JWT_SECRET_KEY=replace_this_with_a_long_random_string_at_least_32_chars

# Token expiry in hours (default: 24 hours = 86400 seconds)
# ACCESS_TOKEN_EXPIRE_HOURS=24

# ── Optional tuning ───────────────────────────────────────────────────────────
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100
# RETRIEVAL_K=4
# BM25_WEIGHT=0.4
# FAISS_WEIGHT=0.6
# LLM_MODEL=llama3-8b-8192
# LLM_TEMPERATURE=0.2
